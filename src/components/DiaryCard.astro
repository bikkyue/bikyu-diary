---
import { formatDate } from '../lib/markdown';

export interface Props {
  slug: string;
  title: string;
  created_at: string;
}

const { slug, title, created_at } = Astro.props;
---

<article class="card">
  <h2 class="card-title">
    <a href={`/${slug}`}>{title}</a>
  </h2>
  <div class="card-meta">
    <span>{formatDate(created_at)}</span>
  </div>
</article>
