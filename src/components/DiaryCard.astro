---
import { formatDate } from '../lib/markdown';

export interface Props {
  slug: string;
  title: string;
  createdAt: string;
}

const { slug, title, createdAt } = Astro.props;
---

<article class="card">
  <h2 class="card-title">
    <a href={`/${slug}`}>{title}</a>
  </h2>
  <div class="card-meta">
    <span>{formatDate(createdAt)}</span>
  </div>
</article>
