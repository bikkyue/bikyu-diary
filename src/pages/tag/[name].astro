---
import Layout from '../../components/Layout.astro';
import DiaryCard from '../../components/DiaryCard.astro';
import { getDiariesByTag } from '../../lib/db';

const { name } = Astro.params;
const runtime = Astro.locals.runtime;
const db = runtime?.env?.DB;

if (!name) {
  return Astro.redirect('/tags');
}

const tagName = decodeURIComponent(name);
let diaries: Awaited<ReturnType<typeof getDiariesByTag>> = [];
let error = '';

if (db) {
  try {
    diaries = await getDiariesByTag(db, tagName);
  } catch (e) {
    error = 'データベースの接続に失敗しました。';
    console.error(e);
  }
}
---

<Layout title={`タグ: ${tagName}`}>
  <h1>タグ: {tagName}</h1>
  
  {error && (
    <div class="card">
      <p class="text-secondary">{error}</p>
    </div>
  )}
  
  {!error && diaries.length === 0 && (
    <div class="card">
      <p class="text-secondary">このタグの日記はありません。</p>
    </div>
  )}
  
  {diaries.map(diary => (
    <DiaryCard
      id={diary.id}
      title={diary.title}
      createdAt={diary.created_at}
      tags={diary.tags}
    />
  ))}
  
  <div class="mt-lg">
    <a href="/tags" class="btn btn-secondary">← タグ一覧に戻る</a>
  </div>
</Layout>
