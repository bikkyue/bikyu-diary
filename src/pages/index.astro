---
import Layout from '../components/Layout.astro';
import DiaryCard from '../components/DiaryCard.astro';
import { getPublishedDiaries } from '../lib/db';

const runtime = Astro.locals.runtime;
const db = runtime?.env?.DB;

let diaries: Awaited<ReturnType<typeof getPublishedDiaries>> = [];
let error = '';

if (db) {
  try {
    diaries = await getPublishedDiaries(db);
  } catch (e) {
    error = 'データベースの接続に失敗しました。';
    console.error(e);
  }
} else {
  error = 'データベースが設定されていません。';
}
---

<Layout title="ホーム">
  {error && (
    <div class="card">
      <p class="text-secondary">{error}</p>
    </div>
  )}
  
  {!error && diaries.length === 0 && (
    <div class="card">
      <p class="text-secondary">まだ日記がありません。</p>
    </div>
  )}
  
  {diaries.map(diary => (
    <DiaryCard
      id={diary.id}
      title={diary.title}
      createdAt={diary.created_at}
      tags={diary.tags}
    />
  ))}
</Layout>
