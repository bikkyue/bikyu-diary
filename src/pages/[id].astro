---
import Layout from '../../components/Layout.astro';
import { getDiaryById } from '../../lib/db';
import { parseMarkdown, formatDate } from '../../lib/markdown';

const { id } = Astro.params;
const runtime = Astro.locals.runtime;
const db = runtime?.env?.DB;

if (!id) {
  return Astro.redirect('/');
}

let diary: Awaited<ReturnType<typeof getDiaryById>> = null;
let error = '';

if (db) {
  try {
    diary = await getDiaryById(db, parseInt(id));
    
    // 下書きは表示しない（公開のみ）
    if (diary && diary.status !== 'published') {
      diary = null;
    }
  } catch (e) {
    error = 'データベースの接続に失敗しました。';
    console.error(e);
  }
}

if (!diary && !error) {
  return Astro.redirect('/');
}

const htmlContent = diary ? parseMarkdown(diary.content) : '';

// OGP用のURL取得
const ogUrl = diary ? `${Astro.url.origin}/${diary.id}` : undefined;
---

<Layout
  title={diary?.title || 'エラー'}
  ogTitle={diary?.title}
  ogUrl={ogUrl}
  ogType="article"
>
  {error && (
    <div class="card">
      <p class="text-secondary">{error}</p>
    </div>
  )}
  
  {diary && (
    <article>
      <header class="diary-detail-header">
        <h1>{diary.title}</h1>
        <div class="card-meta">
          <span>{formatDate(diary.created_at)}</span>
        </div>
        {diary.tags.length > 0 && (
          <div class="tags mt-md">
            {diary.tags.map(tag => (
              <a href={`/tag/${tag}`} class="tag">{tag}</a>
            ))}
          </div>
        )}
      </header>
      
      {diary.thumbnail && (
        <img 
          src={diary.thumbnail} 
          alt={diary.title}
          style="width: 100%; border-radius: var(--border-radius); margin-bottom: var(--spacing-xl);"
        />
      )}
      
      <div class="markdown-content" set:html={htmlContent} />
      
      <div class="mt-lg">
        <a href="/" class="btn btn-secondary">← 一覧に戻る</a>
      </div>
    </article>
  )}
</Layout>
