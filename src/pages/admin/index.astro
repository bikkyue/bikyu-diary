---
import Layout from '../../components/Layout.astro';
import DiaryCard from '../../components/DiaryCard.astro';
import { getAllDiaries } from '../../lib/db';

const runtime = Astro.locals.runtime;
const db = runtime?.env?.DB;

let diaries: Awaited<ReturnType<typeof getAllDiaries>> = [];
let error = '';

if (db) {
  try {
    diaries = await getAllDiaries(db);
  } catch (e) {
    error = 'データベースの接続に失敗しました。';
    console.error(e);
  }
}
---

<Layout title="管理画面" isAdmin={true}>
  <div class="admin-header">
    <h1>日記管理</h1>
    <div class="admin-actions">
      <a href="/admin/new" class="btn btn-primary">+ 新規作成</a>
      <a href="/admin/upload" class="btn btn-secondary">ファイルインポート</a>
      <a href="/admin/images" class="btn btn-secondary">画像アップロード</a>
    </div>
  </div>
  
  {error && (
    <div class="card">
      <p class="text-secondary">{error}</p>
    </div>
  )}
  
  {!error && diaries.length === 0 && (
    <div class="card">
      <p class="text-secondary">まだ日記がありません。</p>
    </div>
  )}
  
  {diaries.map(diary => (
    <div class="card">
      <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: var(--spacing-md);">
        <div style="flex: 1;">
          <h3 class="card-title" style="margin-bottom: var(--spacing-sm);">
            <a href={`/${diary.id}`}>{diary.title}</a>
          </h3>
          <div class="card-meta">
            <span>{new Date(diary.created_at).toLocaleDateString('ja-JP')}</span>
            <span class={`status-badge status-${diary.status}`}>
              {diary.status === 'published' ? '公開' : '下書き'}
            </span>
          </div>
          {diary.tags.length > 0 && (
            <div class="tags mt-md">
              {diary.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
        <div class="admin-actions">
          <a href={`/admin/edit/${diary.id}`} class="btn btn-secondary">編集</a>
          <button 
            class="btn btn-danger delete-btn" 
            data-id={diary.id}
            data-title={diary.title}
          >
            削除
          </button>
        </div>
      </div>
    </div>
  ))}
</Layout>

<script>
  document.querySelectorAll('.delete-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const target = e.target as HTMLButtonElement;
      const id = target.dataset.id;
      const title = target.dataset.title;
      
      if (!confirm(`「${title}」を削除しますか？`)) {
        return;
      }
      
      try {
        const response = await fetch(`/api/diary/${id}`, {
          method: 'DELETE'
        });
        
        if (response.ok) {
          window.location.reload();
        } else {
          alert('削除に失敗しました。');
        }
      } catch (error) {
        alert('削除に失敗しました。');
      }
    });
  });
</script>
