---
import Layout from '../../components/Layout.astro';

const runtime = Astro.locals.runtime;
const bucket = runtime?.env?.BUCKET;

if (!bucket) {
  return Astro.redirect('/');
}

const menuItems = [
  {
    href: '/admin/images',
    label: '画像管理',
    description: '画像のアップロード・一覧・削除',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="32" height="32">
      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
      <circle cx="8.5" cy="8.5" r="1.5"/>
      <polyline points="21 15 16 10 5 21"/>
    </svg>`,
  },
];
---

<Layout title="管理画面">
  <h1>管理画面</h1>

  <div class="admin-grid">
    {menuItems.map((item) => (
      <a href={item.href} class="admin-card card">
        <div class="admin-card-icon" set:html={item.icon} />
        <h2>{item.label}</h2>
        <p class="text-secondary">{item.description}</p>
      </a>
    ))}
  </div>

  <div class="mt-lg">
    <a href="/" class="btn btn-secondary">← 一覧に戻る</a>
  </div>
</Layout>

<style>
  h1 {
    margin-bottom: var(--spacing-lg);
  }

  .admin-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: var(--spacing-md);
  }

  .admin-card {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease;
  }

  .admin-card:hover {
    border-color: var(--primary-color);
  }

  .admin-card h2 {
    margin: 0;
    font-size: 1.1rem;
  }

  .admin-card p {
    margin: 0;
    font-size: 0.875rem;
  }

  .admin-card-icon {
    color: var(--text-secondary);
  }
</style>
