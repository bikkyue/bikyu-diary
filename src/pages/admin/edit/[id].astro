---
import Layout from '../../../components/Layout.astro';
import { getDiaryById } from '../../../lib/db';

const { id } = Astro.params;
const runtime = Astro.locals.runtime;
const db = runtime?.env?.DB;

if (!id) {
  return Astro.redirect('/admin');
}

let diary: Awaited<ReturnType<typeof getDiaryById>> = null;
let error = '';

if (db) {
  try {
    diary = await getDiaryById(db, parseInt(id));
  } catch (e) {
    error = 'データベースの接続に失敗しました。';
    console.error(e);
  }
}

if (!diary && !error) {
  return Astro.redirect('/admin');
}
---

<Layout title={diary ? `編集: ${diary.title}` : 'エラー'} isAdmin={true}>
  {error && (
    <div class="card">
      <p class="text-secondary">{error}</p>
    </div>
  )}
  
  {diary && (
    <>
      <h1>日記を編集</h1>
      
      <form id="diary-form" class="card" data-id={diary.id}>
        <div class="form-group">
          <label for="title">タイトル</label>
          <input type="text" id="title" name="title" value={diary.title} required />
        </div>

        
        <div class="form-group">
          <label for="content">
            本文（マークダウン）
            <span id="char-count" class="text-secondary" style="font-weight: normal; font-size: 0.85rem; margin-left: var(--spacing-sm);"></span>
          </label>
          <textarea id="content" name="content" required>{diary.content}</textarea>
        </div>
        
        <div class="form-group">
          <label for="tags">タグ（カンマ区切り）</label>
          <input type="text" id="tags" name="tags" value={diary.tags.join(', ')} />
        </div>
        
        <div class="form-group">
          <label for="thumbnail">サムネイルURL</label>
          <input type="text" id="thumbnail" name="thumbnail" value={diary.thumbnail || ''} />
        </div>
        
        <div class="form-group">
          <label for="status">公開状態</label>
          <select id="status" name="status">
            <option value="draft" selected={diary.status === 'draft'}>下書き</option>
            <option value="published" selected={diary.status === 'published'}>公開</option>
          </select>
        </div>
        
        <div class="admin-actions">
          <button type="submit" class="btn btn-primary">更新</button>
          <a href="/admin" class="btn btn-secondary">キャンセル</a>
        </div>
      </form>
    </>
  )}
</Layout>

<script>
  const form = document.getElementById('diary-form') as HTMLFormElement;
  const diaryId = form?.dataset.id;
  const contentTextarea = document.getElementById('content') as HTMLTextAreaElement;
  const charCountSpan = document.getElementById('char-count') as HTMLSpanElement;
  
  // 文字数カウント関数
  function updateCharCount() {
    const count = contentTextarea.value.length;
    charCountSpan.textContent = `(${count.toLocaleString()}文字)`;
  }
  
  // 初期表示
  if (contentTextarea && charCountSpan) {
    updateCharCount();
    contentTextarea.addEventListener('input', updateCharCount);
  }
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const data = {
      title: formData.get('title'),
      content: formData.get('content'),
      tags: formData.get('tags')?.toString().split(',').map(t => t.trim()).filter(Boolean) || [],
      thumbnail: formData.get('thumbnail') || undefined,
      status: formData.get('status')
    };
    
    try {
      const response = await fetch(`/api/diary/${diaryId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      
      if (response.ok) {
        window.location.href = '/admin';
      } else {
        const result = await response.json();
        alert(result.error || '更新に失敗しました。');
      }
    } catch (error) {
      alert('更新に失敗しました。');
    }
  });
</script>
