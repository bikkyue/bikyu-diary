---
import Layout from '../components/Layout.astro';
import { getAllTags } from '../lib/db';

const runtime = Astro.locals.runtime;
const db = runtime?.env?.DB;

let tags: Awaited<ReturnType<typeof getAllTags>> = [];
let error = '';

if (db) {
  try {
    tags = await getAllTags(db);
  } catch (e) {
    error = 'データベースの接続に失敗しました。';
    console.error(e);
  }
}
---

<Layout title="タグ一覧">
  <h1>タグ一覧</h1>
  
  {error && (
    <div class="card">
      <p class="text-secondary">{error}</p>
    </div>
  )}
  
  {!error && tags.length === 0 && (
    <div class="card">
      <p class="text-secondary">タグがありません。</p>
    </div>
  )}
  
  {tags.length > 0 && (
    <div class="card">
      <div class="tags" style="gap: var(--spacing-sm);">
        {tags.map(tag => (
          <a href={`/tag/${tag.name}`} class="tag" style="font-size: 0.9rem; padding: var(--spacing-sm) var(--spacing-md);">
            {tag.name} ({tag.count})
          </a>
        ))}
      </div>
    </div>
  )}
</Layout>
